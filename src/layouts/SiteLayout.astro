---
import '../styles/global.css';
import Hamburger from '../components/Hamburger.astro';
import Sidebar from '../components/Sidebar.astro';
import { useTranslations } from '@i18n/utils';
import type { UILanguages } from '@i18n/ui';

interface Props {
  pageTitle: string
  description?: string
}

const { pageTitle, description } = Astro.props;
const locale = Astro.currentLocale as UILanguages;
const t = useTranslations(locale);
const siteDescription = description || t('site.description');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | SeCOrTo</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonicalURL} />
    <slot name="seo-head" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={siteDescription} />
    {/* Inline script previene flash en tema oscuro */}
    <script is:inline>function getInitialTheme(){const e=localStorage?.getItem("theme");return"string"==typeof e?e:window.matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light"}const theme=getInitialTheme();document.documentElement.classList.add(theme),window.localStorage.setItem("theme",theme);</script>
    <style>
      @media (min-width: 1440px) {
        html {
          font-size: 18px;
        }
      }

      @media (min-width: 2160px) {
        html {
          font-size: 24px;
        }
      }
      .header-title {
        font-size: 2.625rem;
      }
    </style>
  </head>
  <body>
    <Hamburger />
    <Sidebar>
      <slot name="langpicker" slot="langpicker" />
    </Sidebar>
    <div class="content">
      <slot />
    </div>
    <script>
      import { initSidebar } from "@client/sidebar";
      initSidebar(document.querySelector('.hamburger'));
    </script>
  </body>
</html>
