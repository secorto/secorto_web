---
import SiteLayout from "@layouts/SiteLayout.astro";
import SEOHeadHomepage from '@components/SEOHeadHomepage.astro';
import intro from '@assets/img/intro.inline.svg?raw'
import Footer from '@components/Footer.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import LanguagePicker from '@components/LanguagePicker.astro'
import { buildHomeLink } from '@i18n/languagePickerUtils'
import type { UILanguages } from '@i18n/ui'
import { languageKeys } from '@i18n/ui'

const pageTitle = "Página de inicio";
const links = Object.fromEntries(languageKeys.map(l => [l, buildHomeLink(l)])) as Record<UILanguages, import('@i18n/languagePickerUtils').TranslationLink>

---

<SEOHeadHomepage slot="seo-head" currentLocale="es" />

<SiteLayout pageTitle={pageTitle}>
  <LanguagePicker slot="langpicker" links={links} />
  <Fragment set:html={intro} />
  <main class="main-content">
    <div>
      <h1>Soy Sergio Carlos Orozco Torres</h1>
      <p>👨🏼‍🎓 <a href={getRelativeLocaleUrl('es', 'about')}>Especialista en seguridad informática</a> con amplios conocimientos en <a href="trabajo">desarrollo de software</a></p>
      <p>🗣️ He dado <a href="charla">charlas</a> en diferentes <a href="comunidad">comunidades</a> por toda Colombia</p>
      <p>📝 Además de haber escrito <a href="blog">articulos</a> sobre diversos temas</p>
      <p>🛠️ Participo en <a href="proyecto">proyectos</a> de código libre</p>
    </div>
    <slot />
  </main>
  <Footer />
</SiteLayout>
