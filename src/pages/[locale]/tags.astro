---
import BaseLayout from '@layouts/BaseLayout.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { type UILanguages } from '@i18n/ui'
import { useTranslations } from '@i18n/utils'
import { buildCollectionLink, buildLanguageLinks } from '@i18n/languagePickerUtils'
import { sectionsConfig, type SectionType } from '@domain/section'
import { buildGlobalTagGroups, type TagGroup, type TagGroupSectionInput } from '@domain/tags'
import { filterByLocale } from '@utils/paths'
import { buildTagIndexPaths, type TagIndexPath } from '@utils/staticPathsBuilder.adapters'

export async function getStaticPaths() {
  return await buildTagIndexPaths()
}

const { locale } = Astro.params as { locale: UILanguages }
const { allSectionEntries } = Astro.props as TagIndexPath['props']
const t = useTranslations(locale)
const pageTitle = t('tags.index_title')
const links = buildLanguageLinks(l => buildCollectionLink(l, 'tags'))

// Construir sectionInputs a partir de datos cacheados (sin fetch)
const sectionInputs: TagGroupSectionInput[] = []

for (const [sectionKey, config] of Object.entries(sectionsConfig) as [SectionType, (typeof sectionsConfig)[SectionType]][]) {
  const localeEntries = filterByLocale(allSectionEntries[config.name], locale)

  sectionInputs.push({
    section: sectionKey,
    sectionSlug: config.routes[locale],
    sectionLabel: t(config.translationKey),
    entries: localeEntries
  })
}

const tagGroups: TagGroup[] = buildGlobalTagGroups(locale, sectionInputs)
---

<BaseLayout pageTitle={pageTitle} description={t('tags.index_description')}>
  <LanguagePicker slot="langpicker" links={links} />

  <section>
    <p data-testid="tags-description">{t('tags.index_description')}</p>

    {tagGroups.length === 0 ? (
      <p>{t('tags.index_no_tags')}</p>
    ) : (
      <ul class="tag-groups" data-testid="global-tag-groups">
        {tagGroups.map((group) => (
          <li class="tag-group" data-testid={`global-tag-${group.canonicalTag}`}>
            <h2>{group.localizedTag}</h2>
            <p>
              {t('tags.available_in')}:
              {group.references.map((reference, index) => (
                <Fragment>
                  {index > 0 && ' / '}
                  <a href={`/${locale}/${reference.sectionSlug}/tags/${encodeURIComponent(reference.tagSlug)}`}>
                    {reference.sectionLabel}
                  </a>
                </Fragment>
              ))}
            </p>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .tag-groups {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .tag-group {
    border: dotted 2px var(--colors-primary);
    border-radius: .5em;
    padding: 1rem;
  }

  .tag-group h2 {
    margin: 0 0 .5rem;
  }
</style>
