---
import BaseLayout from '@layouts/BaseLayout.astro'
import Tags from '@components/Tags.astro'
import ListPost from '@components/ListPost.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import { buildTagPaths } from '@utils/staticPathsBuilder'
import { buildTagsPageContext } from '@utils/sectionContext'
import { getLocalesWithTag } from '@utils/translationHelpers'
import { buildTagLink, type TranslationLink } from '@i18n/languagePickerUtils'
import { resolveCanonical } from '@i18n/rootMap'
import type { UILanguages } from '@i18n/ui'
import { languageKeys } from '@i18n/ui'

export async function getStaticPaths() {
  return await buildTagPaths()
}

const { locale, section, tag } = Astro.params
const t = useTranslations(locale)

// Construir contexto de página (valida sección y carga posts)
const context = await buildTagsPageContext(section, locale, tag)

const { config, posts, tags } = context
const pageTitle = `${t(config.translationKey)} - ${tag}`
const metaDescription = `${config.taggedKey ? t(config.taggedKey) : t(config.translationKey)} ${tag}`

const canonicalSection = resolveCanonical(section, locale as UILanguages)
const availableLangs = getLocalesWithTag(context.allEntries, tag)
const links = Object.fromEntries(
  languageKeys.map(l => [l, buildTagLink(l, canonicalSection, `tags/${tag}`, availableLangs)])
) as Record<UILanguages, TranslationLink>
---

<head>
  <meta charset="utf-8" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDescription} />
</head>

<BaseLayout pageTitle={pageTitle}>
  <LanguagePicker slot="langpicker" links={links} />
  <Tags route={`/${locale}/${section}/tags/`} tags={tags} current={tag} />
  {config.taggedKey && <p>{t(config.taggedKey)} {tag}</p>}

  {posts.length === 0 ? (
    <div class="warning">
      <p>{t('tags.untranslated_notice')}</p>
    </div>
  ) : (
    <div>
      <ListPost posts={posts} basePath={`${locale}/${config.routes[locale]}`} />
    </div>
  )}
</BaseLayout>
