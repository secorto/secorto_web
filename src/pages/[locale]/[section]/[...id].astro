---
import { render, getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import Comments from '@components/Comments.astro'
import BlogTalkPostView from '@components/BlogTalkPostView.astro'
import WorkProjectCommunityView from '@components/WorkProjectCommunityView.astro'
import SEOHeadDetail from '@components/SEOHeadDetail.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import { getCanonicalMetadata, getPageMetadata } from '@utils/translationMetadata'
import { buildAllDetailPaths, type DetailPath } from '@utils/staticPathsBuilder.adapters'
import { buildDetailLink, buildLanguageLinks } from '@i18n/languagePickerUtils'
import { findCanonicalSectionKey } from '@i18n/rootMap'
import { resolveSeriesCanonicalLocale } from '@i18n/buildTranslationMap'
import type { UILanguages } from '@i18n/ui'
import { defaultLang } from '@i18n/ui'

export async function getStaticPaths() {
  return await buildAllDetailPaths(getCollection)
}

const { locale, section } = Astro.params as { locale: UILanguages; section: string }
const { entry, localeEntryMap, config } = Astro.props as DetailPath['props']
const t = useTranslations(locale)

const availableLocales = Object.keys(localeEntryMap) as UILanguages[]
const seriesCanonicalLocale = resolveSeriesCanonicalLocale(availableLocales)

const canonicalSection = findCanonicalSectionKey(section, locale)
const links = buildLanguageLinks(l => buildDetailLink(l, canonicalSection, localeEntryMap))

const { canonicalLocale, shouldNoindex } = getCanonicalMetadata({
  entryDraft: Boolean(entry.data.draft),
  currentLocale: locale,
  currentCleanId: entry.cleanId,
  seriesCanonicalLocale
})

// Use existing helper to build the canonical path so formatting is centralized
const canonicalLink = buildDetailLink(canonicalLocale, canonicalSection, localeEntryMap)
const canonicalPath = canonicalLink.href
const alternates = availableLocales.map(lk => ({
  locale: lk,
  url: buildDetailLink(lk, canonicalSection, localeEntryMap).href
}))
// Prefer defaultLang version for x-default when available, otherwise fall back to canonicalPath
const defaultLink = buildDetailLink(defaultLang, canonicalSection, localeEntryMap)
const defaultPath = defaultLink.href || canonicalPath

// Map category to component
const detailComponentMap = {
  post: BlogTalkPostView,
  experience: WorkProjectCommunityView
} as const

const DetailComponent = detailComponentMap[config.category]
const routeSlug = config.routes[locale]

const { Content } = await render(entry)
const { pageTitle, pageDescription } = getPageMetadata(entry, t(config.translationKey))
---

<SEOHeadDetail
  slot="seo-head"
  canonicalPath={canonicalPath}
  alternates={alternates}
  defaultPath={defaultPath}
  noindex={shouldNoindex}
/>

<BaseLayout pageTitle={pageTitle} description={pageDescription}>
  <LanguagePicker slot="langpicker" links={links} />
  {entry.data.draft && (
    <div class="untranslated-notice" role="status">
      <p>{t('post.draft_notice')}</p>
    </div>
  )}

  <DetailComponent
    locale={locale}
    routeSlug={routeSlug}
    entry={entry}
    Content={Content}
  />

  <Comments />
</BaseLayout>
