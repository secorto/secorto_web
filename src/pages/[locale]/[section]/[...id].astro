---
import { render, getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import Comments from '@components/Comments.astro'
import BlogTalkPostView from '@components/BlogTalkPostView.astro'
import WorkProjectCommunityView from '@components/WorkProjectCommunityView.astro'
import SEOHeadDetail from '@components/SEOHeadDetail.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import { getAvailableLocaleEntries } from '@utils/translationHelpers'
import { getCanonicalMetadata, getPageMetadata } from '@utils/translationMetadata'
import { buildAllDetailPaths, type DetailPath } from '@utils/staticPathsBuilder'
import { buildDetailLink, type TranslationLink } from '@i18n/languagePickerUtils'
import { resolveCanonical } from '@i18n/rootMap'
import { resolveSeriesCanonicalLocale } from '@i18n/buildTranslationMap'
import type { UILanguages } from '@i18n/ui'
import { languageKeys } from '@i18n/ui'

export async function getStaticPaths() {
  return await buildAllDetailPaths(getCollection)
}

const { locale, section } = Astro.params as { locale: UILanguages; section: string }
const { entry, allEntries, config } = Astro.props as DetailPath['props']
const t = useTranslations(locale)

const localeEntryMap = getAvailableLocaleEntries(allEntries, entry.cleanId)
const availableLocales = Object.keys(localeEntryMap) as UILanguages[]
const seriesCanonicalLocale = resolveSeriesCanonicalLocale(availableLocales)

const canonicalSection = resolveCanonical(section, locale)
const links = Object.fromEntries(
  languageKeys.map(l => [l, buildDetailLink(l, canonicalSection, localeEntryMap)])
) as Record<UILanguages, TranslationLink>

const { canonicalLocale, canonicalId, shouldNoindex } = getCanonicalMetadata({
  entryDraft: Boolean(entry.data.draft),
  currentLocale: locale,
  currentCleanId: entry.cleanId,
  seriesCanonicalLocale
})

// Extract page metadata
const { Content } = await render(entry)
const { pageTitle, pageDescription } = getPageMetadata(entry, t(config.translationKey))
const routeSlug = config.routes[locale]
---

<SEOHeadDetail
  slot="seo-head"
  config={config}
  cleanId={canonicalId}
  canonicalLocale={canonicalLocale}
  availableLocales={availableLocales}
  noindex={shouldNoindex}
/>

<BaseLayout pageTitle={pageTitle} description={pageDescription}>
  <LanguagePicker slot="langpicker" links={links} />
  {entry.data.draft && (
    <div class="untranslated-notice" role="status">
      <p>{t('post.draft_notice')}</p>
    </div>
  )}

  {config.detailComponent === 'BlogTalkPostView' ? (
    <BlogTalkPostView
      locale={locale}
      routeSlug={routeSlug}
      entry={entry}
      Content={Content}
    />
  ) : (
    <WorkProjectCommunityView
      locale={locale}
      entry={entry}
      Content={Content}
    />
  )}

  <Comments />
</BaseLayout>
