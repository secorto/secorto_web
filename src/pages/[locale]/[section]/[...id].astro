---
import { render, getCollection, getEntry } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import Comments from '@components/Comments.astro'
import BlogTalkPostView from '@components/BlogTalkPostView.astro'
import WorkProjectCommunityView from '@components/WorkProjectCommunityView.astro'
import SEOHeadDetail from '@components/SEOHeadDetail.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { getSectionConfigByRoute } from '@utils/sections'
import { extractCleanId } from '@utils/ids'
import { useTranslations } from '@i18n/utils'
import { getAvailableLocaleEntries } from '@utils/translationHelpers'
import { getCanonicalMetadata, getPageMetadata } from '@utils/translationMetadata'
import { buildAllDetailPaths } from '@utils/staticPathsBuilder'
import { buildDetailLink, type TranslationLink } from '@i18n/languagePickerUtils'
import { resolveCanonical } from '@i18n/rootMap'
import type { UILanguages } from '@i18n/ui'
import { languageKeys } from '@i18n/ui'

export async function getStaticPaths() {
  return await buildAllDetailPaths(getCollection)
}

const { locale, section, id } = Astro.params
const t = useTranslations(locale)

const config = getSectionConfigByRoute(section, locale)
const entry = await getEntry(config.collection, `${locale}/${id}`)
if(!entry) throw new Error(`Entry not found for locale "${locale}" and id "${id}" in collection "${config.collection}"`)
const context = { entry, config, locale }

const cleanId = extractCleanId(entry.id)

// Single getCollection call provides entries for locale availability and link building
const allEntries = await getCollection(config.collection)
const localeEntryMap = getAvailableLocaleEntries(allEntries, cleanId)
const availableLocales = Object.keys(localeEntryMap) as UILanguages[]
const seriesCanonicalLocale = (availableLocales.includes('es' as UILanguages)
  ? 'es'
  : (availableLocales[0] ?? locale)) as UILanguages

const canonicalSection = resolveCanonical(section as string, locale as UILanguages)
const links = Object.fromEntries(
  languageKeys.map(l => [l, buildDetailLink(l, canonicalSection, cleanId, localeEntryMap)])
) as Record<UILanguages, TranslationLink>

const { canonicalLocale, canonicalId, shouldNoindex } = getCanonicalMetadata({
  entryDraft: Boolean(entry.data.draft),
  currentLocale: context.locale,
  currentCleanId: cleanId,
  seriesCanonicalLocale
})

// Extract page metadata
const { Content } = await render(entry)
const { pageTitle, pageDescription } = getPageMetadata(entry, t(config.translationKey))
const routeSlug = config.routes[context.locale]
---

<SEOHeadDetail
  slot="seo-head"
  config={config}
  cleanId={canonicalId}
  canonicalLocale={canonicalLocale}
  availableLocales={availableLocales}
  noindex={shouldNoindex}
/>

<BaseLayout pageTitle={pageTitle} description={pageDescription}>
  <LanguagePicker slot="langpicker" links={links} />
  {entry.data.draft && (
    <div class="untranslated-notice" role="status">
      <p>{t('post.draft_notice')}</p>
    </div>
  )}

  {config.detailComponent === 'BlogTalkPostView' ? (
    <BlogTalkPostView
      locale={context.locale}
      routeSlug={routeSlug}
      entry={entry}
      Content={Content}
    />
  ) : (
    <WorkProjectCommunityView
      locale={context.locale}
      entry={entry}
      Content={Content}
    />
  )}

  <Comments />
</BaseLayout>
