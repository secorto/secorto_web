---
import { render, getCollection } from 'astro:content'
import BaseLayout from '@layouts/BaseLayout.astro'
import Comments from '@components/Comments.astro'
import BlogTalkPostView from '@components/BlogTalkPostView.astro'
import WorkProjectCommunityView from '@components/WorkProjectCommunityView.astro'
import SEOHead from '@components/SEOHead.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import { getPageMetadata } from '@utils/translationMetadata'
import { buildAllDetailPaths } from '@utils/staticPathsBuilder.adapters'

export async function getStaticPaths() {
  return await buildAllDetailPaths(getCollection)
}

const { locale } = Astro.params
const { entry, localeLinks, config, alternates, defaultPath } = Astro.props

const t = useTranslations(locale)
// Map category to component
const detailComponentMap = {
  post: BlogTalkPostView,
  experience: WorkProjectCommunityView
} as const

const DetailComponent = detailComponentMap[config.category]
const routeSlug = config.routes[locale]

const { Content } = await render(entry)
const { pageTitle, pageDescription } = getPageMetadata(entry, t(config.translationKey))
---

<SEOHead
  slot="seo-head"
  alternates={alternates}
  defaultPath={defaultPath}
  noindex={Boolean(entry.data.draft)}
/>

<BaseLayout pageTitle={pageTitle} description={pageDescription}>
  <LanguagePicker slot="langpicker" links={localeLinks} />
  {entry.data.draft && (
    <div class="untranslated-notice" role="status">
      <p>{t('post.draft_notice')}</p>
    </div>
  )}

  <DetailComponent
    locale={locale}
    routeSlug={routeSlug}
    entry={entry}
    Content={Content}
  />

  <Comments />
</BaseLayout>
