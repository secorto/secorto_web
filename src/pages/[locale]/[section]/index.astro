---
import BaseLayout from '@layouts/BaseLayout.astro'
import SEOHeadIndex from '@components/SEOHeadIndex.astro'
import ListPost from '@components/ListPost.astro'
import ListWork from '@components/ListWork.astro'
import Tags from '@components/Tags.astro'
import { loadSectionByRoute } from '@utils/sectionLoader'
import { useTranslations } from '@i18n/utils'
import type { UILanguages } from '@i18n/ui'
import { buildSectionIndexPaths } from '@utils/staticPathsBuilder'
import { buildSectionContext } from '@utils/sectionContext'
import { isCollectionWithTags, type PostLikeEntry, type WorkLikeEntry } from '@domain/post'

export async function getStaticPaths() {
  return await buildSectionIndexPaths()
}

const { locale, section } = Astro.params as { locale: UILanguages; section: string }
const t = useTranslations(locale)

// Validar que la sección existe y obtener configuración
const { config } = buildSectionContext(section, locale)

// Cargar posts y datos de la sección
const sectionData = await loadSectionByRoute(section, locale)

const { posts, tags } = sectionData
const pageTitle = t(config.translationKey)
---

<SEOHeadIndex slot="seo-head" config={config} currentLocale={locale} />

<BaseLayout pageTitle={pageTitle}>
  {isCollectionWithTags(config.collection) && tags.length > 0 && (
    <Tags route={`/${locale}/${section}/tags/`} tags={tags} />
  )}
  {config.listComponent === 'ListPost' && (
    // TODO(debt): cast necesario porque loadSectionByRoute retorna CollectionKey genérico — owner: @sergio.orozcot — until: 2026-06-01
    <ListPost posts={posts as PostLikeEntry[]} basePath={`${locale}/${config.routes[locale]}`} />
  )}
  {config.listComponent === 'ListWork' && (
    // TODO(debt): cast necesario porque loadSectionByRoute retorna CollectionKey genérico — owner: @sergio.orozcot — until: 2026-06-01
    <ListWork posts={posts as WorkLikeEntry[]} basePath={`${locale}/${config.routes[locale]}`} lang={locale} />
  )}
</BaseLayout>
