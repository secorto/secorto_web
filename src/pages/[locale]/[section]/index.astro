---
import BaseLayout from '@layouts/BaseLayout.astro'
import SEOHeadIndex from '@components/SEOHeadIndex.astro'
import ListPost from '@components/ListPost.astro'
import ListWork from '@components/ListWork.astro'
import Tags from '@components/Tags.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import type { UILanguages } from '@i18n/ui'
import { buildSectionIndexPaths, type SectionPath } from '@utils/staticPathsBuilder'
import { isCollectionWithTags, type PostEntry } from '@domain/post'
import { buildCollectionLink, buildLanguageLinks } from '@i18n/languagePickerUtils'
import { findCanonicalSectionKey } from '@i18n/rootMap'

export async function getStaticPaths() {
  return await buildSectionIndexPaths()
}

const { locale, section } = Astro.params as { locale: UILanguages; section: string }
const { config, posts, tags } = Astro.props as SectionPath['props']
const t = useTranslations(locale)
const pageTitle = t(config.translationKey)

const canonicalSection = findCanonicalSectionKey(section, locale)
const links = buildLanguageLinks(l => buildCollectionLink(l, canonicalSection))
---

<SEOHeadIndex slot="seo-head" config={config} currentLocale={locale} />

<BaseLayout pageTitle={pageTitle}>
  <LanguagePicker slot="langpicker" links={links} />
  {isCollectionWithTags(config.collection) && tags.length > 0 && (
    <Tags route={`/${locale}/${section}/tags/`} tags={tags} />
  )}
  {config.listComponent === 'ListPost' && (
    <ListPost posts={posts} basePath={`${locale}/${config.routes[locale]}`} />
  )}
  {config.listComponent === 'ListWork' && (
    // TODO(debt): cast necesario porque `SectionPath['props'].posts` está tipado como `PostEntry<CollectionKey>[]` en vez de un tipo específico de colección — owner: @sergio.orozcot — until: 2026-06-01
    <ListWork posts={posts as PostEntry<'work'>[]} basePath={`${locale}/${config.routes[locale]}`} lang={locale} />
  )}
</BaseLayout>
