---
import BaseLayout from '@layouts/BaseLayout.astro'
import SEOHead from '@components/SEOHead.astro'
import ListPost from '@components/ListPost.astro'
import ListWork from '@components/ListWork.astro'
import Tags from '@components/Tags.astro'
import LanguagePicker from '@components/LanguagePicker.astro'
import { useTranslations } from '@i18n/utils'
import { defaultLang, type UILanguages } from '@i18n/ui'
import { buildSectionIndexPaths, type SectionPath } from '@utils/staticPathsBuilder.adapters'
import { buildCollectionLink, buildLanguageLinks } from '@i18n/languagePickerUtils'
import { findCanonicalSectionKey } from '@i18n/rootMap'

export async function getStaticPaths() {
  return await buildSectionIndexPaths()
}

const { locale, section } = Astro.params as { locale: UILanguages; section: string }
const sectionProps = Astro.props as SectionPath['props']
const config = sectionProps.config
const tags = sectionProps.tags
const t = useTranslations(locale)
const pageTitle = t(config.translationKey)

const canonicalSection = findCanonicalSectionKey(section, locale)
const links = buildLanguageLinks(l => buildCollectionLink(l, canonicalSection))
const defaultPath = links[defaultLang].href
---

<BaseLayout pageTitle={pageTitle}>
  <SEOHead slot="seo-head" defaultPath={defaultPath} links={links} />
  <LanguagePicker slot="langpicker" links={links} />
  {tags.length > 0 && (
    <Tags route={`/${locale}/${section}/tags/`} tags={tags} />
  )}
  {config.category === 'post' && (
    <ListPost posts={sectionProps.posts} basePath={`${locale}/${config.routes[locale]}`} />
  )}
  {config.category === 'experience' && (
    <ListWork posts={sectionProps.posts} basePath={`${locale}/${config.routes[locale]}`} lang={locale} />
  )}
</BaseLayout>
