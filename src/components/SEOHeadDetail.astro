---
/**
 * SEO metadata component for detail pages (blog posts, talks, work, etc.)
 * Receives fully-built canonical/alternate/default URLs from the page.
 */
import type { Alternative } from '@domain/pageDetail'
import AlternateLinks from './AlternateLinks.astro'

interface Props {
  /** Canonical path for this page (relative, e.g. /es/blog/slug) */
  canonicalPath: string
  /** Array of precomputed absolute alternates { locale, url } */
  alternates: Alternative[]
  /** Default (x-default) path (relative) */
  defaultPath: string
  /** Whether to mark as noindex (for draft/untranslated content) */
  noindex?: boolean
}

const { canonicalPath, alternates, defaultPath, noindex = false } = Astro.props
const site = import.meta.env.SITE ?? ''
const canonicalUrl = `${site}${canonicalPath}`
const absoluteAlternates = alternates.map(a => ({ locale: a.locale, url: `${site}${a.url}` }))
const absoluteDefault = `${site}${defaultPath}`
---

<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex" />}
<AlternateLinks alternates={absoluteAlternates} defaultUrl={absoluteDefault} />
