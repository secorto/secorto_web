---
/**
 * Reusable component for rendering alternate language (hreflang) links
 */
import type { Alternative } from '@domain/pageDetail'


interface Props {
  /** Array of alternate language links */
  alternates: Alternative[]
}

const { alternates } = Astro.props
---

{alternates.map(({ locale, url }) => (
  <link rel="alternate" hreflang={locale} href={url} />
))}

