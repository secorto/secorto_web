---
import type { ContentItem, PyBaqItem } from '../types/home'

interface Props {
  blog: ContentItem
  talk: ContentItem
  pybaq: PyBaqItem
}

const { blog, talk, pybaq } = Astro.props as Props
---

<div class="highlights">
  <div class="highlights-cards">
    <a class="highlight-card" href={blog.url} data-testid="highlight-blog">
      <span class="highlight-label">{blog.sectionLabel}</span>
      <h2 class="highlight-title">{blog.title}</h2>
      {blog.excerpt && <p class="highlight-excerpt">{blog.excerpt}</p>}
      <span class="highlight-cta">{blog.cta}</span>
    </a>

    <a class="highlight-card" href={talk.url} data-testid="highlight-talk">
      <span class="highlight-label">{talk.sectionLabel}</span>
      <h2 class="highlight-title">{talk.title}</h2>
      {talk.excerpt && <p class="highlight-excerpt">{talk.excerpt}</p>}
      <span class="highlight-cta">{talk.cta}</span>
    </a>
  </div>

  <a class="pybaq-callout" href={pybaq.url} target="_blank" rel="noopener noreferrer">
    <div class="pybaq-header">
      <span class="pybaq-label">{pybaq.label}</span>
      <span class="pybaq-role">{pybaq.role}</span>
      <span class="pybaq-since">{pybaq.since}</span>
    </div>
    <p class="pybaq-desc">{pybaq.description}</p>
    <span class="pybaq-cta">{pybaq.cta} →</span>
  </a>
</div>
