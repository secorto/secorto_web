---
import type { ContentItem, PyBaqItem } from '../types/home'

interface Props {
  blog?: ContentItem
  talk?: ContentItem
  pybaq: PyBaqItem
}

const { blog, talk, pybaq } = Astro.props as Props
---

<div class="highlights">
  <div class="highlights-cards">
    {([blog, talk] as ContentItem[])
      .filter(Boolean)
      .map((item, idx) => (
        <a class="highlight-card" href={item.url} data-testid={`highlight-${idx}`}>
          <span class="highlight-label">{item.sectionLabel}</span>
          <h2 class="highlight-title">{item.title}</h2>
          {item.excerpt && <p class="highlight-excerpt">{item.excerpt}</p>}
          <span class="highlight-cta">{item.cta}</span>
        </a>
      ))}
  </div>

  <a class="pybaq-callout" href={pybaq.url} target="_blank" rel="noopener noreferrer">
    <div class="pybaq-header">
      {pybaq.label && <span class="pybaq-label">{pybaq.label}</span>}
      <span class="pybaq-role">{pybaq.role}</span>
      <span class="pybaq-name">{pybaq.since}</span>
    </div>
    <p class="pybaq-desc">{pybaq.description}</p>
    <span class="pybaq-cta">{pybaq.cta} →</span>
  </a>
</div>
<style>

