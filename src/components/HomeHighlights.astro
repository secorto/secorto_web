---
interface ContentItem {
  sectionLabel: string
  title: string
  excerpt: string
  url: string
  cta: string
}

interface PyBaqItem {
  role: string
  since: string
  description: string
  url: string
  cta: string
}

interface Props {
  blog?: ContentItem
  talk?: ContentItem
  pybaq: PyBaqItem
}

const { blog, talk, pybaq } = Astro.props
---

<div class="highlights">
  {(blog || talk) && (
    <div class="highlights-cards">
      {blog && (
        <a class="highlight-card" href={blog.url}>
          <span class="highlight-label">{blog.sectionLabel}</span>
          <h2 class="highlight-title">{blog.title}</h2>
          {blog.excerpt && <p class="highlight-excerpt">{blog.excerpt}</p>}
          <span class="highlight-cta">{blog.cta}</span>
        </a>
      )}
      {talk && (
        <a class="highlight-card" href={talk.url}>
          <span class="highlight-label">{talk.sectionLabel}</span>
          <h2 class="highlight-title">{talk.title}</h2>
          {talk.excerpt && <p class="highlight-excerpt">{talk.excerpt}</p>}
          <span class="highlight-cta">{talk.cta}</span>
        </a>
      )}
    </div>
  )}

  <a class="pybaq-callout" href={pybaq.url} target="_blank" rel="noopener noreferrer">
    <div class="pybaq-header">
      <span class="pybaq-label">{pybaq.role}</span>
      <span class="pybaq-name">{pybaq.since}</span>
    </div>
    <p class="pybaq-desc">{pybaq.description}</p>
    <span class="pybaq-cta">{pybaq.cta} →</span>
  </a>
</div>

<style>
  .highlights {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .highlights-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 829px) {
    .highlights-cards {
      grid-template-columns: 1fr;
    }
  }

  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    box-shadow: 0 0 8px var(--colors-primary);
    background: var(--colors-background);
    color: var(--colors-text);
    transition: transform 0.2s ease-out, box-shadow 0.2s ease-out;
  }

  .highlight-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px var(--colors-primary);
  }

  .highlight-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--colors-primary);
  }

  .highlight-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--colors-heading);
    margin: 0;
    line-height: 1.3;
  }

  .highlight-excerpt {
    font-size: 0.9rem;
    color: var(--colors-text);
    margin: 0;
    line-height: 1.5;
    /* Limitar a 3 líneas */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .highlight-cta {
    margin-top: auto;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--colors-primary);
  }

  /* Callout PyBAQ */
  .pybaq-callout {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    background: var(--colors-sidebar-background);
    color: var(--colors-sidebar-text);
    transition: opacity 0.2s ease-out;
  }

  .pybaq-callout:hover {
    opacity: 0.9;
  }

  .pybaq-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .pybaq-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--colors-sidebar-hover);
  }

  .pybaq-name {
    font-size: 0.85rem;
    color: var(--colors-sidebar-text);
    opacity: 0.8;
  }

  .pybaq-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--colors-sidebar-text);
  }

  .pybaq-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--colors-sidebar-hover);
    margin-top: 0.25rem;
  }
</style>
