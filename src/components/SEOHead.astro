---
/**
 * Componente unificado para metadatos SEO.
 * Recibe rutas relativas y normaliza a URLs absolutas usando `import.meta.env.SITE`.
 */
import { resolveDefaultLocaleFromLinks, type TranslationLink } from '@domain/translationLink'
import { buildAlternatesFromLinks } from '@i18n/languagePickerUtils'
import AlternateLinks from './AlternateLinks.astro'

interface Props {
  links: TranslationLink[]
  /** Marcar como noindex cuando aplique */
  noindex?: boolean
}

const { links, noindex = false } = Astro.props
const site = import.meta.env.SITE

const alternates = buildAlternatesFromLinks(links)
const normalizedAlternates = alternates.map(a => ({ locale: a.locale, url: `${site}${a.url}` }))
const defaultLink = resolveDefaultLocaleFromLinks(links)
const normalizedDefault = defaultLink ? `${site}${defaultLink.href}` : undefined
---
{noindex && <meta name="robots" content="noindex" />}
{normalizedDefault && <link rel="alternate" hreflang="x-default" href={normalizedDefault} />}
<AlternateLinks alternates={normalizedAlternates} />
