---
import { Image } from "astro:assets";
interface Props {
  title: string
  url: string
  image?: ImageMetadata
  excerpt?: string
  cta?: string
}
const { title, url, image, excerpt = '', cta = 'Ver más' } = Astro.props
---

<a class="card" href={url}>
  {image &&
    <Image src={image} alt="featured image" class="card-image" />
  }
  <span class="card-content">
    <h2 class="card-title">{title}</h2>
    {excerpt && <p class="card-excerpt">{excerpt}</p>}
    <div class="card-details">
      <slot/>
    </div>
    <div class="card-cta">
      {cta}
    </div>
  </span>
</a>
<style>
  .card {
    box-sizing: border-box;
    min-width: 0px;
    box-shadow: 0 0 8px var(--colors-primary);
    margin: 0px 0px 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    transition: box-shadow 0.3s ease-out 0.1s, transform 0.3s ease-out, opacity 0.2s ease-out;
    flex: 0 1 100%;
    padding: 1rem;
    background: var(--colors-background);
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    align-items: flex-start;
    min-height: 260px;
  }
  @container (min-width: 1440px) {
    .card {
      min-height: 300px;
    }
  }
  @container (max-width: 700px) {
    .card {
      flex-direction: column;
      align-items: center;
      min-height: auto;
    }
  }
  .card:hover {
    transform: translate(0px, -4px);
    box-shadow: 0 2px 14px var(--colors-hover);
  }
  .card-content {
    box-sizing: border-box;
    margin: 0px;
    min-width: 0px;
    color: var(--colors-primary);
    flex: 1;
    min-width: 0;
  }
  @container (max-width: 700px) {
    .card-content {
      text-align: center;
    }
  }
  .card-title {
    margin: 0;
  }
  .card-excerpt {
    margin: 0.5rem 0 0 0;
    color: var(--colors-text);
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .card-details {
    color: var(--colors-text);
  }
  .card-image {
    flex-shrink: 0;
    width: 320px;
    height: 240px;
    object-fit: contain;
    border-radius: 6px;
    display: block;
  }
  @container (min-width: 1440px) {
    .card-image {
      width: 380px;
      height: 280px;
    }
  }
  .card-cta {
    margin-top: auto;
    font-weight: 600;
    color: var(--colors-hover);
  }
</style>
