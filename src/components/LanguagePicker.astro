---
import type { TranslationLink } from "@domain/translationLink"
import { adaptLanguageLinks } from "@i18n/languagePickerAdapter"

interface Props {
  links: TranslationLink[]
}

const { links } = Astro.props
const items = adaptLanguageLinks(links)
---

<div class="language-picker">
  {items.map((item) => {
    if (!item.accessible) return (
      <span
        class="disabled"
        role="link"
        aria-disabled="true"
        tabindex="-1"
        aria-label={item.title ? `${item.title}: ${item.label}` : undefined}
        title={item.title}
        data-disabled-reason={item.reason}
        data-testid={`lang-${item.locale}`}
      >
        {item.text}
      </span>
    )

    return (
      <a
        href={item.href}
        title={item.title}
        aria-label={item.label}
        aria-describedby={item.reasonId}
        data-testid={`lang-${item.locale}`}
      >
        {item.text}
        {item.title ? <span id={item.reasonId} class="sr-only">{item.title}</span> : null}
      </a>
    )
  })}
</div>
