---
import { languageKeys, icons as uiIcons, ui as uiStrings } from "@i18n/ui"
import type { UILanguages } from "@i18n/ui"
import { resolveCanonical } from "@i18n/rootMap"
import { buildHomeLink, buildTagLink, buildDetailLink, buildCollectionLink, type TranslationLink } from "@i18n/languagePickerUtils"
import { buildTranslationPayload } from "@i18n/buildTranslationMap"
import type { TranslationEntry } from "@i18n/buildTranslationMap"
import { getPostsByLocale, getUniqueTags } from "@utils/paths"
import { sectionsConfig } from "@domain/section"
import type { SectionType } from "@domain/section"
import { isCollectionWithTags } from "@domain/post"

const segments = Astro.url.pathname.split("/").filter(Boolean)
const currentLang = segments[0] as UILanguages
const rawSection = segments[1]
const slug = segments.slice(2).join("/")

const isHomePage = !rawSection
const isTagPage = slug.startsWith("tags")
const isDetailPage = Boolean(slug) && !isHomePage

const canonicalSection = isHomePage ? "" : resolveCanonical(rawSection, currentLang)

let structures: { seriesByKey?: Record<string, Record<string, TranslationEntry>>; slugIndex?: Record<string, string> } | undefined = undefined
if (!isHomePage) {
  const sectionCfg = sectionsConfig[canonicalSection as SectionType]
  if (sectionCfg) {
    const payload = await buildTranslationPayload(sectionCfg.collection)
    structures = { seriesByKey: payload.seriesByKey, slugIndex: payload.slugIndex }
  }
}
const seriesKey = structures?.slugIndex?.[slug]
const availableLocales = isDetailPage && seriesKey ? (structures?.seriesByKey?.[seriesKey] ?? {}) : {}

const tagName = isTagPage ? slug.replace('tags/', '') : ''
const tagAvailableLocales = new Set<UILanguages>()
if (isTagPage && tagName) {
  const sectionCfg = sectionsConfig[canonicalSection as SectionType]
  if (sectionCfg && isCollectionWithTags(sectionCfg.collection)) {
    for (const lang of languageKeys) {
      const posts = await getPostsByLocale(sectionCfg.collection, lang)
      if (getUniqueTags(posts).includes(tagName)) tagAvailableLocales.add(lang)
    }
  }
}

function buildLink(targetLang: UILanguages): TranslationLink {
  if (isHomePage) return buildHomeLink(targetLang)
  if (isTagPage) return buildTagLink(targetLang, canonicalSection, slug, tagAvailableLocales)
  if (isDetailPage) return buildDetailLink(targetLang, canonicalSection, slug, availableLocales)
  return buildCollectionLink(targetLang, canonicalSection)
}

const reasonMeta = {
  missing: { marker: uiIcons.missing, titleKey: 'translation.disabled.missing' as const },
  draft:   { marker: uiIcons.draft,   titleKey: 'translation.disabled.draft' as const },
}
---

<div class="language-picker">
  {languageKeys.map((targetLang) => {
    const link = buildLink(targetLang)
    const meta = link.disabledReason && reasonMeta[link.disabledReason]
    const text = meta ? `${link.label} ${meta.marker}` : link.label
    const title = meta && uiStrings[targetLang][meta.titleKey]
    const ariaLabel = title ? `${title}: ${link.label}` : undefined

    if (!link.isAvailable) return (
      <span
        class="disabled"
        role="link"
        aria-disabled="true"
        tabindex="-1"
        aria-label={ariaLabel}
        title={title}
        data-disabled-reason={link.disabledReason ?? ''}
        data-testid={`lang-${targetLang}`}
      >
        {text}
      </span>
    )

    return (
      <a href={link.href} title={title} aria-label={ariaLabel} data-testid={`lang-${targetLang}`}>
        {text}
      </a>
    )
  })}
</div>
